{
  "name": "buddy-builder",
  "version": "1.4.7",
  "description": "A desktop GUI for Claude Code. Manage multiple sessions, search conversations, and work with AI — visually.",
  "main": "dist/main.cjs",
  "bin": {
    "buddy-builder": "./bin/buddy-builder.cjs"
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "bin/**/*"
  ],
  "scripts": {
    "cli": "npx tsx src/cli.ts",
    "build": "node scripts/build.js",
    "start": "npm run build && npx electron .",
    "dev": "node scripts/build.js --watch & npx electronmon .",
    "prepublishOnly": "npm run build",
    "probe": "npx tsx src/probe.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "electron",
    "gui",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "esbuild": "^0.27.3",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "electronmon": {
    "logLevel": "verbose"
  },
  "dependencies": {
    "electron": "^40.6.1",
    "electron-updater": "^6.8.3",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.1",
    "zod": "^4.3.6"
  }
}
