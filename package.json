{
  "name": "buddy-builder",
  "version": "1.4.0",
  "description": "Programmatic wrapper around Claude Code CLI",
  "main": "dist/main.cjs",
  "scripts": {
    "cli": "npx tsx src/cli.ts",
    "build": "node scripts/build.js",
    "start": "npm run build && npx electron .",
    "dev": "node scripts/build.js --watch & npx electronmon .",
    "dist": "npm run build && npx electron-builder --mac --win --linux",
    "dist:mac": "npm run build && npx electron-builder --mac",
    "dist:win": "npm run build && npx electron-builder --win",
    "dist:linux": "npm run build && npx electron-builder --linux",
    "probe": "npx tsx src/probe.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "esbuild": "^0.27.3",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "electronmon": {
    "logLevel": "verbose"
  },
  "build": {
    "appId": "com.buddy-builder.app",
    "productName": "Buddy Builder",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "eran-broder",
      "repo": "buddy-builder"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "marked": "^17.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.1",
    "zod": "^4.3.6"
  }
}
